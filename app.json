{
  "expo": {
    "name": "Sewfolio",
    "slug": "sewfolio",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "sewfolio",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}