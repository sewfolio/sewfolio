{
  "expo": {
    "name": "Sewfolio",
    "slug": "sewfolio",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "sewfolio",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sewfolio.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "67bfecf0-ccbb-412a-b0b0-8c7f292d09c0"
      }
    }
  }
}
